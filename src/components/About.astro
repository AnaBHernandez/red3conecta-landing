---
const { t } = Astro.props;
const a = t.about;
---

<section id="about" class="about">
  <div class="about-container">
    <div class="about-content">
      <h2
        data-anim
        data-delay="0"
        set:html={a.title.replace("Red3Conecta?", "<span>Red3Conecta?</span>")}
      />
      <div class="about-line" data-anim data-delay="240" aria-hidden="true">
      </div>

      <ul class="about-items" role="list">
        {
          a.items.map((text: any, i: any) => (
            <li class="about-item" data-anim data-delay={340 + i * 120}>
              <span class="about-item__num" aria-hidden="true">
                {String(i + 1).padStart(2, "0")}
              </span>
              <p>{text}</p>
            </li>
          ))
        }
      </ul>

      <div class="about-mini-visual" aria-hidden="true">
        <span class="node">Entitats</span>
        <span class="line"></span>
        <span class="node">Professionals</span>
        <span class="line"></span>
        <span class="node">Persones</span>
      </div>
    </div>

    <div class="about-image" data-anim data-delay="180">
      <div class="about-image__frame">
        <img src="/imagenes/image.png" alt={a.img_alt} loading="lazy" />
        <div class="about-image__tag">
          <span class="about-image__tag-dot"></span>
          {a.active_tag}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes float-img {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }
  @keyframes dot-ping {
    0% {
      box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.55);
    }
    70% {
      box-shadow: 0 0 0 6px rgba(34, 197, 94, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(34, 197, 94, 0);
    }
  }
  @keyframes bg-pulse {
    0%,
    100% {
      opacity: 0.5;
    }
    50% {
      opacity: 1;
    }
  }
  [data-anim] {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.55s ease,
      transform 0.55s ease;
  }
  [data-anim].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .about {
    padding: clamp(3rem, 5vw, 4.5rem) clamp(1.25rem, 3vw, 2.5rem);
    background: var(--color-background);
    position: relative;
    overflow: hidden;
  }
  .about::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        ellipse at 15% 80%,
        rgba(249, 115, 22, 0.06) 0%,
        transparent 55%
      ),
      radial-gradient(
        ellipse at 85% 20%,
        rgba(216, 185, 143, 0.08) 0%,
        transparent 55%
      );
    animation: bg-pulse 4s ease-in-out 1;
    pointer-events: none;
  }

  .about-container {
    max-width: 1500px;
    width: 95%;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
    gap: 2rem;
    position: relative;
    z-index: 1;
    border-radius: 15px;
    padding: 20px;
    background-color: var(--color-surface);
    box-sizing: border-box;
  }

  .about-content {
    background: linear-gradient(145deg, #ffffff8f 0%, #ff800057 100%);
    padding: 2rem;
    border-radius: 20px;
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.06);
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    height: autos;
    min-width: 0;
    box-sizing: border-box;
  }

  .about-content h2 {
    font-size: clamp(2.5, 4vw, 4rem);
    line-height: 1.15;
    font-weight: 800;
    color: #1f1a16;
    margin: 0 0 0.4rem;

  }
  .about-content h2 span {
    color: #c66a24;
  }

  .about-line {
    height: 3px;
    width: 0;
    background: linear-gradient(90deg, #f97316, #fdba74);
    border-radius: 999px;
    margin-bottom: 1.5rem;
    transform: none !important;
    transition:
      width 0.85s 0.1s ease,
      opacity 0.3s ease !important;
  }
  .about-line.is-visible {
    width: 56px;
  }

  .about-items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .about-item {
    padding: 0.75rem 0.9rem 0.75rem 1rem;
    border-left: 2px solid transparent;
    border-radius: 0 10px 10px 0;
    transition:
      border-color 240ms,
      background 240ms,
      transform 240ms;
    cursor: default;
    transform-origin: left center;
  }
  .about-item:hover {
    border-left-color: #c66a24;
    background: rgba(198, 106, 36, 0.07);
    transform: translateX(5px);
  }
  .about-item__num {
    display: block;
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 1px;
    color: #c66a24;
    opacity: 0.45;
    margin-bottom: 0.2rem;
    font-family: var(--font-primary);
    transition: opacity 240ms;
  }
  .about-item:hover .about-item__num {
    opacity: 1;
  }
  .about-item p {
    font-size: 1.2rem;
    line-height: 1.65;
    color: #4a3b31;
    margin: 0;
  }

  .about-image {
    min-height: auto;
    position: relative;
    min-width: auto;
    box-sizing: border-box;
  }
  .about-image__frame {
    position: relative;
    height: 500px;
    min-height: 0;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.1);
    animation: float-img 3s ease-in-out 1;
    transition: box-shadow 300ms;
  }
  .about-image__frame:hover {
    box-shadow: 0 26px 60px rgba(0, 0, 0, 0.15);
  }
  .about-image__frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 500ms ease;
  }
  .about-image__frame:hover img {
    transform: scale(1.04);
  }

  .about-image__tag {
    position: absolute;
    bottom: 1.1rem;
    left: 1.1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: rgba(255, 250, 242, 0.92);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(198, 106, 36, 0.2);
    border-radius: 999px;
    padding: 0.35rem 0.85rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: #6d5b49;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.09);
    transition:
      transform 250ms,
      box-shadow 250ms;
    z-index: 2;
  }
  .about-image__frame:hover .about-image__tag {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.13);
  }
  .about-image__tag-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #22c55e;
    flex-shrink: 0;
    animation: dot-ping 2.5s ease-in-out 1;
  }

  @media (min-width: 1024px) {
    .about-container {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }

    .about-image {
      order: 0;
    }
  }

  @media (min-width: 600px) and (max-width: 1023px) {
    .about-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .about-image {
      order: -1;
      min-height: auto;
    }
    .about-image__frame {
      height: 220px;
      min-height: 220px;
      animation: none;
    }
  }
  @media (max-width: 450px) {
    .about-image__frame {
      height: 180px;
      min-height: 180px;
    }
    .about {
      padding: 3.5rem 1.25rem;
    }
    .about-content {
      padding: 1.75rem 1.5rem 1.5rem;
    }
    .about-item {
      padding: 0.65rem 0.75rem 0.65rem 0.85rem;
    }
  }

  .about-mini-visual {
    margin-top: 2rem;
    display: flex;
    align-items: center;
    gap: 0.8rem;
    opacity: 0.75;
  }
  .node {
    padding: 0.5rem 0.8rem;
    border-radius: 999px;
    background: rgba(198, 106, 36, 0.12);
    color: #c66a24;
    font-size: 0.8rem;
    font-weight: 700;
  }
  .line {
    width: 28px;
    height: 2px;
    background: rgba(198, 106, 36, 0.25);
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const delay = Number(el.dataset.delay ?? 0);
          setTimeout(() => el.classList.add("is-visible"), delay);
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.12 },
  );

  document
    .querySelectorAll("#about [data-anim]")
    .forEach((el) => observer.observe(el));
</script>
