---
const { icon, title, description, variant = "default" } = Astro.props;
---
<div class={`card card--${variant}`}>
  <img src={icon} alt={title} class="card__icon" />
  <div class="card__content">
    <h3>{title}</h3>
    <p>{description}</p>
  </div>
</div>
<style>
    h3{
    
    }
   .card{
    padding: 5px;
    height: 70px;
    margin: 10px;
    font-size: 12px;
    border-radius: 2%;
    background-color: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.3);
    border-left: 8px solid;  
    display: flex;
    flex-direction: row;
    align-items: center;     
}
    .card__content {
        display: flex;
        flex-direction: column;   
        gap: 0.25rem;
        margin-left: 25px;
        }
        .card__content h3 {
  margin-bottom: 0;  
}
.card__content p {
  margin-top: 0;           
}
    .card--talk{
        border-color: var(--color-secondary);
    }
    .card--formacion{
       border-color: var(--color-primary);
    }
    .card--insertion{
        border-color:var(--color-red);
    }
    .card__icon{
        width: 45px;
        height: 45px;
        flex-shrink: 0;
    }
    .card--caso {
    border-left: none;
    border-top: 4px solid orange;
    border-bottom: 4px solid orange;
}
</style>