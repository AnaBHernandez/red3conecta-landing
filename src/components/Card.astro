---
const { icon, title, description, variant = "default" } = Astro.props;
---

<div class={`card card--${variant}`} data-card>
  <button class="card__button" aria-expanded="false">
    <img src={icon} alt={title} class="card__icon" />
    <h3 class="card__titulo">{title}</h3>
    <span class="card__flecha">▾</span>
  </button>

  <div class="card__body">
    <p>{description}</p>
  </div>
</div>

<style>
  /* CONTENEDOR — compacto por defecto, se expande al abrirse */
  .card {
    width: fit-content;
    min-width: 320px;
    max-width: 420px;
    padding: 0;
    margin: 8px 0;
    border-radius: 0.75rem;
    background-color: rgba(225, 120, 0, 0.02);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    overflow: hidden;
    transition:
      width 0.4s ease,
      max-width 0.4s ease,
      box-shadow 0.25s ease;
  }

  /* ABIERTA — ocupa todo el ancho disponible */
  .card--abierta {
    width: 100%;
    max-width: 100%;
  }

  /* CABECERA — siempre visible */
  .card__button {
    display: flex;
    align-items: center;
    flex-direction: row;
    gap: 0.75rem;
    width: 100%;
    padding: 10px 16px;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    min-height: 70px;
    transition: background 0.2s ease;
  }

  .card__button:hover {
    background-color: rgba(255, 202, 137, 0.3);
  }

  .card__icon {
    width: 52px;
    height: 52px;
    flex-shrink: 0;
    transition: width 0.3s ease, height 0.3s ease, opacity 0.3s ease;
  }

  /* Icono se encoge al abrir */
  .card--abierta .card__icon {
    width: 36px;
    height: 36px;
    opacity: 0.7;
  }

  .card__titulo {
    flex: 1;
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    transition: font-size 0.3s ease;
  }

  /* Título se reduce al abrir */
  .card--abierta .card__titulo {
    font-size: 0.85rem;
    opacity: 0.75;
  }

  .card__flecha {
    flex-shrink: 0;
    font-size: 1.1rem;
    color: var(--color-black);
    transition: transform 0.3s ease;
  }

  .card--abierta .card__flecha {
    transform: rotate(180deg);
  }

  /* CUERPO — cerrado */
  .card__body {
    max-height: 0;
    overflow: hidden;
    padding: 0 1.2rem;
    transition:
      max-height 0.4s ease,
      padding 0.4s ease;
  }

  /* CUERPO — abierto */
  .card--abierta .card__body {
    max-height: 300px;
    padding: 0.5rem 1.5rem 1.2rem;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  .card__body p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-black);
    opacity: 0;
    transform: translateX(-8px); 
    transition: opacity 0.3s ease 0.15s, transform 0.3s ease 0.15s;
  }

  .card--abierta .card__body p {
    opacity: 1;
    transform: translateX(0);
  }

  /* VARIANTES */
  .card--caso {
    border-top: 3px solid var(--color-peach-warm);
    border-bottom: 3px solid var(--color-peach-warm);
    border-radius: 3rem;
  }

  .card--talk    { border-left: 6px solid var(--color-secondary); }
  .card--formacion { border-left: 6px solid var(--color-primary); }
  .card--insertion { border-left: 6px solid var(--color-red); }

  .card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.316);
  }
</style>

<script>
  const tarjetas = document.querySelectorAll("[data-card]");

  tarjetas.forEach((tarjeta) => {
    const boton = tarjeta.querySelector(".card__button");

    boton?.addEventListener("click", () => {
      const estaAbierta = tarjeta.classList.contains("card--abierta");

      // Cierra todas
      tarjetas.forEach((t) => {
        t.classList.remove("card--abierta");
        t.querySelector(".card__button")?.setAttribute("aria-expanded", "false");
      });

      // Si estaba cerrada, abre esta
      if (!estaAbierta) {
        tarjeta.classList.add("card--abierta");
        boton.setAttribute("aria-expanded", "true");
      }
    });
  });
</script>