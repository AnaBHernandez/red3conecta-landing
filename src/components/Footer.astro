---
const { t } = Astro.props;
const f = t.footer;
---

<footer class="footer">
  <div class="footer__glow" aria-hidden="true"></div>
  <div class="footer__ring" aria-hidden="true"></div>
  <div class="footer__orb" aria-hidden="true"></div>

  <div class="footer__top">
    <div class="footer__brand">
      <h2 class="footer__name">Red<span>3</span>Conecta</h2>
      <p class="footer__desc">{f.desc}</p>
      <a href={`mailto:${f.email}`} class="footer__email">
        ✉ {f.email}
      </a>

      <div class="footer__social" aria-label={f.aria_social}>
        <a href="#" class="footer__social-btn" aria-label={f.aria_linkedin}>
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"
            ></path>
          </svg>
        </a>
        <a href="#" class="footer__social-btn" aria-label={f.aria_instagram}>
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2m-.2 2A3.6 3.6 0 0 0 4 7.6v8.8C4 18.39 5.61 20 7.6 20h8.8a3.6 3.6 0 0 0 3.6-3.6V7.6C20 5.61 18.39 4 16.4 4H7.6m9.65 1.5a1.25 1.25 0 0 1 1.25 1.25A1.25 1.25 0 0 1 17.25 8 1.25 1.25 0 0 1 16 6.75a1.25 1.25 0 0 1 1.25-1.25M12 7a5 5 0 0 1 5 5 5 5 0 0 1-5 5 5 5 0 0 1-5-5 5 5 0 0 1 5-5m0 2a3 3 0 0 0-3 3 3 3 0 0 0 3 3 3 3 0 0 0 3-3 3 3 0 0 0-3-3z"
            ></path>
          </svg>
        </a>
        <a href="#" class="footer__social-btn" aria-label={f.aria_twitter}>
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"
            ></path>
          </svg>
        </a>
      </div>

      <div class="footer__chips">
        {f.chips.map((chip: any) => <span>{chip}</span>)}
      </div>
    </div>

    <nav class="footer__nav" aria-label="Peu de pàgina">
      <span class="footer__nav-label">Navegación</span>

      <a href="#about">{t.nav.why}</a>
      <a href="#challenges">{t.nav.challenges}</a>
      <a href="#ally">{t.nav.ally}</a>
      <a href="#ecosystem">{t.nav.ecosystem}</a>
    </nav>

    <div class="footer__info">
      <span class="footer__nav-label">{f.partners_label}</span>
      {
        f.partners.map((name: any, i: any) => (
          <div class="footer__partner">
            <span
              class={`footer__partner-dot${i === 2 ? " footer__partner-dot--alt" : ""}`}
            />
            <p>{name}</p>
          </div>
        ))
      }

      <div class="footer__newsletter">
        <p class="footer__newsletter-lbl">{f.newsletter_label}</p>
        <div class="footer__newsletter-row">
          <input
            type="email"
            id="nl-email"
            placeholder={f.newsletter_placeholder}
            class="footer__newsletter-input"
            aria-label="Adreça de correu electrònic"
          />
          <button
            class="footer__newsletter-btn"
            id="nl-btn"
            type="button"
            aria-label={f.aria_subscribe}>→</button
          >
        </div>
        <p class="footer__newsletter-ok" id="nl-ok" style="display:none;">
          {f.newsletter_ok}
        </p>
      </div>
    </div>
  </div>

  <div class="footer__divider">
    <span class="footer__divider-name">Red<em>3</em>Conecta</span>
  </div>

  <div class="footer__bottom">
    <p set:html={f.bottom} />
    <p>{f.rights}</p>
  </div>
</footer>

<style>
  @keyframes glow-breathe {
    0%,
    100% {
      opacity: 1;
      transform: translateX(-50%) scaleX(1);
    }
    50% {
      opacity: 0.5;
      transform: translateX(-50%) scaleX(0.8);
    }
  }
  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes dot-ping {
    0% {
      box-shadow: 0 0 0 0 rgba(249, 115, 22, 0.45);
    }
    70% {
      box-shadow: 0 0 0 5px rgba(249, 115, 22, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(249, 115, 22, 0);
    }
  }
  @keyframes arrow-nudge {
    0%,
    100% {
      transform: translateX(0);
    }
    50% {
      transform: translateX(3px);
    }
  }
  @keyframes name-shimmer {
    0% {
      background-position: -300% center;
    }
    100% {
      background-position: 300% center;
    }
  }
  @keyframes ring-spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
  @keyframes scan-line {
    0% {
      transform: translateX(-100%);
      opacity: 0;
    }
    10%,
    90% {
      opacity: 1;
    }
    100% {
      transform: translateX(100vw);
      opacity: 0;
    }
  }
  @keyframes orb-drift {
    0%,
    100% {
      transform: translate(0, 0);
    }
    50% {
      transform: translate(20px, -14px);
    }
  }

  .footer {
    background-color: #1a0d04;
    padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1.25rem, 3vw, 2.5rem) 1rem;
    border-top: 1px solid rgba(249, 115, 22, 0.22);
    border-radius: 24px 24px 0 0;
    position: relative;
    overflow: hidden;
  }

  .footer::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 120px;
    background: linear-gradient(
      to bottom,
      rgba(237, 207, 176, 0.06) 0%,
      transparent 100%
    );
    pointer-events: none;
    z-index: 0;
  }

  .footer::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 160px;
    height: 2px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(249, 115, 22, 0.35),
      transparent
    );
    pointer-events: none;
    z-index: 2;
    animation: scan-line 8s ease-in-out infinite;
  }
  .footer__glow {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 260px;
    background: radial-gradient(
      ellipse at top,
      rgba(249, 115, 22, 0.18) 0%,
      transparent 65%
    );
    pointer-events: none;
    animation: glow-breathe 5s ease-in-out infinite;
  }

  .footer__ring {
    position: absolute;
    bottom: 2rem;
    right: 2rem;
    width: 90px;
    height: 90px;
    border: 1px dashed rgba(249, 115, 22, 0.15);
    border-radius: 50%;
    animation: ring-spin 18s linear infinite;
    pointer-events: none;
  }

  .footer__orb {
    position: absolute;
    bottom: -30px;
    left: 5%;
    width: 160px;
    height: 160px;
    background: radial-gradient(
      circle,
      rgba(249, 115, 22, 0.07) 0%,
      transparent 70%
    );
    border-radius: 50%;
    pointer-events: none;
    animation: orb-drift 10s ease-in-out infinite;
  }
  .footer__top {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.6fr 1fr 1.4fr;
    gap: 2rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    position: relative;
    z-index: 1;
  }

  .footer__brand {
    animation: fade-up 0.55s ease both;
  }
  .footer__nav {
    animation: fade-up 0.55s 0.1s ease both;
  }
  .footer__info {
    animation: fade-up 0.55s 0.2s ease both;
  }

  .footer__name {
    font-family: var(--font-primary);
    font-size: 1.4rem;
    font-weight: 800;
    margin: 0 0 0.5rem;
    background: linear-gradient(
      90deg,
      #fdf6ec 30%,
      #fdba74 50%,
      #f97316 60%,
      #fdf6ec 75%
    );
    background-size: 300% auto;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: name-shimmer 5s linear infinite;
  }
  .footer__name span {
    -webkit-text-fill-color: transparent;
  }
  .footer__desc {
    font-size: 0.85rem;
    line-height: 1.65;
    color: #ddc9a0;
    max-width: 280px;
    margin: 0 0 0.75rem;
  }
  .footer__email {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.88rem;
    font-weight: 600;
    color: #fdba74;
    text-decoration: none;
    padding: 6px 14px;
    border: 1px solid rgba(253, 186, 116, 0.25);
    border-radius: 999px;
    background: rgba(253, 186, 116, 0.06);
    transition:
      color 200ms,
      border-color 200ms,
      background 200ms,
      box-shadow 200ms;
  }
  .footer__email:hover {
    color: #fff;
    border-color: rgba(253, 186, 116, 0.55);
    background: rgba(253, 186, 116, 0.13);
    box-shadow: 0 0 14px rgba(253, 186, 116, 0.15);
  }

  .footer__social {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
  }
  .footer__social-btn {
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 9px;
    color: #c9a97a;
    text-decoration: none;
    transition:
      background 200ms,
      color 200ms,
      border-color 200ms,
      transform 200ms,
      box-shadow 200ms;
  }
  .footer__social-btn:hover {
    background: rgba(249, 115, 22, 0.2);
    color: #fdba74;
    border-color: rgba(249, 115, 22, 0.4);
    transform: translateY(-3px);
    box-shadow: 0 6px 16px rgba(249, 115, 22, 0.18);
  }

  .footer__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }
  .footer__chips span {
    font-size: 0.72rem;
    font-weight: 600;
    color: rgba(201, 169, 122, 0.7);
    background: rgba(201, 169, 122, 0.08);
    border: 1px solid rgba(201, 169, 122, 0.15);
    padding: 3px 10px;
    border-radius: 999px;
    transition:
      background 200ms,
      border-color 200ms,
      color 200ms,
      transform 200ms;
    cursor: default;
  }
  .footer__chips span:hover {
    background: rgba(201, 169, 122, 0.16);
    border-color: rgba(201, 169, 122, 0.32);
    color: rgba(201, 169, 122, 1);
    transform: translateY(-1px);
  }

  .footer__nav,
  .footer__info {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    position: relative;
    z-index: 1;
  }
  .footer__nav-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #f97316;
    margin-bottom: 0.35rem;
  }
  .footer__nav a {
    font-size: 0.85rem;
    color: #d9bf9a;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0;
    transition:
      color 200ms,
      gap 200ms;
  }
  .footer__nav a::before {
    content: "→";
    font-size: 0.75rem;
    color: #f97316;
    opacity: 0;
    width: 0;
    overflow: hidden;
    transition:
      opacity 200ms,
      width 200ms;
  }
  .footer__nav a:hover,
  .footer__nav a:focus-visible {
    color: #fdf6ec;
    gap: 0.35rem;
    outline: none;
  }
  .footer__nav a:hover::before,
  .footer__nav a:focus-visible::before {
    opacity: 1;
    width: 0.9rem;
  }

  .footer__partner {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.35rem 0.5rem;
    border-radius: 8px;
    margin: 0 -0.5rem;
    transition:
      background 220ms,
      transform 220ms,
      box-shadow 220ms;
    cursor: default;
  }
  .footer__partner:hover {
    background: rgba(249, 115, 22, 0.12);
    transform: translateX(5px);
    box-shadow: inset 0 0 0 1px rgba(249, 115, 22, 0.2);
  }
  .footer__partner-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #f97316;
    flex-shrink: 0;
    animation: dot-ping 2.8s ease-in-out infinite;
    transition:
      transform 220ms,
      box-shadow 220ms;
  }
  .footer__partner:hover .footer__partner-dot {
    transform: scale(1.6);
    box-shadow: 0 0 8px rgba(249, 115, 22, 0.6);
  }
  .footer__partner-dot--alt {
    background: #fdba74;
    animation-delay: 1.2s;
    animation-name: dot-ping;
  }
  .footer__partner:hover .footer__partner-dot--alt {
    box-shadow: 0 0 8px rgba(253, 186, 116, 0.6);
  }
  .footer__partner p {
    font-size: 0.85rem;
    color: #d9bf9a;
    margin: 0;
    font-weight: 500;
    transition: color 220ms;
  }
  .footer__partner:hover p {
    color: #fdf6ec;
  }

  .footer__newsletter {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
  }
  .footer__newsletter-lbl {
    font-size: 0.72rem;
    font-weight: 700;
    color: rgba(220, 190, 140, 0.9);
    text-transform: uppercase;
    letter-spacing: 0.8px;
    margin: 0 0 0.5rem;
  }
  .footer__newsletter-row {
    display: flex;
    gap: 0.4rem;
  }
  .footer__newsletter-input {
    flex: 1;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    padding: 0.45rem 0.8rem;
    font-size: 0.82rem;
    color: #fdf6ec;
    font-family: var(--font-secondary);
    outline: none;
    min-width: 0;
    transition:
      border-color 200ms,
      background 200ms,
      box-shadow 200ms;
  }
  .footer__newsletter-input::placeholder {
    color: rgba(201, 169, 122, 0.4);
  }
  .footer__newsletter-input:focus {
    border-color: rgba(249, 115, 22, 0.5);
    background: rgba(255, 255, 255, 0.09);
    box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.1);
  }
  .footer__newsletter-btn {
    background: #f97316;
    border: none;
    border-radius: 8px;
    width: 34px;
    height: 34px;
    color: #fff;
    font-size: 1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition:
      background 200ms,
      transform 200ms,
      box-shadow 200ms;
  }
  .footer__newsletter-btn:hover {
    background: #ea580c;
    transform: scale(1.08);
    box-shadow: 0 4px 14px rgba(249, 115, 22, 0.35);
    animation: arrow-nudge 0.6s ease infinite;
  }
  .footer__newsletter-ok {
    font-size: 0.82rem;
    color: #fdba74;
    margin: 0.5rem 0 0;
  }

  .footer__divider {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0.75rem 0 0.6rem;
    text-align: center;
    position: relative;
    z-index: 1;
  }
  .footer__divider::before,
  .footer__divider::after {
    content: "";
    position: absolute;
    top: 50%;
    width: calc(50% - 100px);
    height: 1px;
    background: rgba(255, 255, 255, 0.06);
  }
  .footer__divider::before {
    left: 0;
  }
  .footer__divider::after {
    right: 0;
  }
  .footer__divider-name {
    font-family: var(--font-primary);
    font-size: 1rem;
    font-weight: 800;
    color: rgba(201, 169, 122, 0.3);
    letter-spacing: 2px;
    text-transform: uppercase;
    transition: color 300ms;
  }
  .footer__divider-name:hover {
    color: rgba(201, 169, 122, 0.55);
  }
  .footer__divider-name em {
    font-style: normal;
    color: rgba(249, 115, 22, 0.4);
  }

  .footer__bottom {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    position: relative;
    z-index: 1;
  }
  .footer__bottom p {
    font-size: 0.78rem;
    color: rgba(220, 185, 140, 0.7);
    margin: 0;
  }
  .footer__bottom strong {
    color: rgba(235, 205, 160, 0.95);
  }

  @media (max-width: 900px) {
    .footer__top {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
    .footer__brand {
      grid-column: 1 / -1;
    }
    .footer__desc {
      max-width: none;
    }
  }
  @media (max-width: 480px) {
    .footer__top {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }
    .footer__bottom {
      flex-direction: column;
    }
    .footer__divider::before,
    .footer__divider::after {
      display: none;
    }
  }
</style>

<script>
  const btn = document.getElementById("nl-btn");
  const input = document.getElementById("nl-email") as HTMLInputElement | null;
  const ok = document.getElementById("nl-ok") as HTMLElement | null;

  btn?.addEventListener("click", () => {
    if (input && input.value.includes("@")) {
      input.style.display = "none";
      btn.style.display = "none";
      if (ok) ok.style.display = "block";
    }
  });
</script>

<script>
  const btn = document.getElementById("nl-btn");
  const input = document.getElementById("nl-email") as HTMLInputElement | null;
  const ok = document.getElementById("nl-ok") as HTMLElement | null;

  btn?.addEventListener("click", () => {
    if (input && input.value.includes("@")) {
      input.style.display = "none";
      btn.style.display = "none";
      if (ok) ok.style.display = "block";
    }
  });
</script>
