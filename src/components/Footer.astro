---
// Importación del contrato de traducción
import i18n from "../i18n/ca.json";
---

<footer class="footer">
  <div class="footer-content">
    <div>
      <h2>Red3Conecta</h2>
      <p>
        Infraestructura digital col·laborativa construïda amb el tercer sector,
        per al tercer sector.
      </p>
      <p>
        Per a més informació:
        <a href="mailto:contacte@red3conecta.org"> contacte@red3conecta.org </a>
      </p>

      <p>
        <a href="#">LinkedIn del projecte</a>
      </p>
    </div>

    <nav class="footer-links" aria-label="Enlaces del pie de página">
      <a href="#proyecto">Proyecte</a>
      <a href="#impacto">Impacte</a>
      <a href="#ecosistema">Ecosistema</a>
      <a href="#contacto">Contacte</a>
    </nav>
  </div>

  <div class="footer-bottom">
    <p>Projecte impulsat per Factoría F5 i Fundació Formació i Treball.</p>
    <p>© 2026 Red3Conecta. Tots els drets reservats.</p>
  </div>
</footer>

<style>
  .footer {
    background-color: #e8dccb;
    color: #5b3a29;
    padding: 3rem 2rem;
    text-align: center;
    border-top: 2px solid #f0d4bf;
  }

  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer h2 {
    color: #c97a3d;
    margin-bottom: 1rem;
  }

  .footer p {
    margin-bottom: 1rem;
  }

  .footer-links {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin: 1.5rem 0;
  }

  .footer-links a {
    color: #c87b4a;
    text-decoration: none;
    font-weight: 600;
  }

  .footer-links a:visited {
    color: #9a5e37;
  } /* WCAG AA */
  .footer-links a:active {
    color: #5b3a29;
  }
</style>
