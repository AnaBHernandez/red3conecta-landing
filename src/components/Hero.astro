---
const { t } = Astro.props;
---

<section class="hero" id="hero-section">
  <div class="hero__card" id="hero-card">
    <span class="corner corner--tl" aria-hidden="true"></span>
    <span class="corner corner--tr" aria-hidden="true"></span>
    <span class="corner corner--bl" aria-hidden="true"></span>
    <span class="corner corner--br" aria-hidden="true"></span>

    <h1 class="hero__title">{t.hero.title}</h1>
    <p class="hero__subtitle">{t.hero.subtitle}</p>

    <div class="hero__cta">
      <a
        href="https://form.asana.com/?k=Xi-unyAAA4uXYNzBzx5bmA&d=1111991690250694"
        target="_blank"
        rel="noopener noreferrer"
        class="cta-btn cta-btn--primary"
      >
        <span class="cta-btn__arrow" aria-hidden="true">→</span>
        <span class="cta-btn__text">
          <strong class="cta-btn__label">{t.hero.btn_demo}</strong>
          <span class="cta-btn__desc">Veure la plataforma en funcionament.</span
          >
        </span>
      </a>

      <a
        href="#"
        class="cta-btn cta-btn--secondary"
        aria-disabled="true"
        onclick="return false;"
      >
        <span class="cta-btn__arrow" aria-hidden="true">→</span>
        <span class="cta-btn__text">
          <strong class="cta-btn__label">{t.hero.btn_join}</strong>
          <span class="cta-btn__desc"
            >Forma part de l'ecosistema Red3Conecta.</span
          >
        </span>
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 2.5rem 1.25rem;
    text-align: center;
    background-color: var(--color-cream-light);
    display: flex;
    justify-content: center;
  }

  .hero__card {
    background-color: var(--color-surface-card);
    border-radius: 12px;
    padding: 3rem 2rem;
    width: 100%;
    max-width: 750px;
    position: relative;
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.8s ease,
      transform 0.8s ease;
  }
  .hero__card.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .hero__title {
    margin-bottom: 0.5rem;
  }
  .hero__subtitle {
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    margin-top: 1.5rem;
  }
  .cta-btn {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1.25rem;
    border: 2px solid var(--color-black);
    border-radius: 8px;
    text-decoration: none;
    color: var(--color-black);
    flex: 1 1 300px;
    max-width: 340px;
    position: relative;
    overflow: hidden;
    transition: transform 0.28s ease;
  }
  .cta-btn__text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    gap: 2px;
  }
  .cta-btn__label {
    font-weight: 800;
  }
  .cta-btn__desc {
    font-size: 0.85rem;
    opacity: 0.8;
  }

  .cta-btn:hover {
    transform: translateY(-4px);
    background-color: rgba(255, 94, 0, 0.272);
  }
  .cta-btn::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      115deg,
      transparent 30%,
      rgba(255, 255, 255, 0.4) 50%,
      transparent 70%
    );
    transform: translateX(-120%);
    transition: transform 0.5s ease;
  }
  .cta-btn:hover::after {
    transform: translateX(120%);
  }

  .corner {
    position: absolute;
    width: 22px;
    height: 22px;
    border-color: var(--color-border);
    border-style: solid;
    border-width: 2.5px;
    opacity: 0;
    transition: opacity 0.5s ease 0.5s;
  }
  .corner--tl {
    top: 14px;
    left: 14px;
    border-right: none;
    border-bottom: none;
  }
  .corner--tr {
    top: 14px;
    right: 14px;
    border-left: none;
    border-bottom: none;
  }
  .corner--bl {
    bottom: 14px;
    left: 14px;
    border-top: none;
    border-right: none;
  }
  .corner--br {
    bottom: 14px;
    right: 14px;
    border-top: none;
    border-left: none;
  }
  .hero__card.is-visible .corner {
    opacity: 1;
  }

  .hero__card {
    background-color: var(--color-surface-card);
    border-radius: 12px;
    padding: 2rem 1rem; /* Móvil < 450px */
    width: 100%;
    max-width: 750px;
    position: relative;
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.8s ease,
      transform 0.8s ease;
  }
  .hero__cta {
    flex-direction: column;
    align-items: center;
  }
  .cta-btn {
    flex: 1 1 100%;
    max-width: 100%;
  }
  @media (min-width: 1024px) {
    .hero {
      padding: 6rem 2rem;
    }
    .hero__card {
      max-width: 900px; /* Expansión visual en escritorio */
    }
    .hero__cta {
      flex-direction: row; /* Mantener horizontal en pantallas grandes */
      gap: 2rem;
    }
    .cta-btn {
      flex: 1 1 340px; /* Tamaño fijo óptimo */
    }
  }

  @media (min-width: 600px) {
    .hero {
      padding: 4rem 2rem;
    }
    .hero__card {
      padding: 4rem 3rem;
    }
  }
  @media (max-width: 450px) {
    .hero {
      padding: 1.5rem 0.5rem;
    }
  }
</style>

<script>
  const heroCard = document.getElementById("hero-card");
  const observer = new IntersectionObserver(
    ([entry]) => {
      if (entry.isIntersecting) heroCard?.classList.add("is-visible");
    },
    { threshold: 0.2 },
  );
  if (heroCard) observer.observe(heroCard);
</script>
