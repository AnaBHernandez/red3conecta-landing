---
const { t } = Astro.props;
---

<nav class="navbar">
  <div class="navbar__container">
    <a href="/" class="navbar__brand">
      <img src="/Modelo_B.png" alt="Logo" width="77" height="77" />
      <h1 class="navbar__title">RED<span>3</span>CONECTA</h1>
    </a>

    <div class="navbar__menu" id="navbar-menu">
      <ul class="navbar__list">
        <li><a href="#about" class="navbar__link">{t.nav.why}</a></li>
        <li>
          <a href="#challenges" class="navbar__link">{t.nav.challenges}</a>
        </li>
        <li><a href="#ally" class="navbar__link">{t.nav.ally}</a></li>
        <li><a href="#ecosystem" class="navbar__link">{t.nav.ecosystem}</a></li>
      </ul>
    </div>

    <div class="navbar__right-group">
      <div class="navbar__lang">
        <a href="/ca/">CA</a> | <a href="/es/">ES</a>
      </div>

      <button
        class="navbar__toggle"
        aria-label="Menú"
        aria-expanded="false"
        aria-controls="navbar-menu"
      >
        <span class="toggle__bar"></span>
        <span class="toggle__bar"></span>
        <span class="toggle__bar"></span>
      </button>
    </div>
  </div>
</nav>

<style>
  @keyframes name-shimmer {
    0% {
      background-position: -300% center;
    }
    100% {
      background-position: 300% center;
    }
  }

  .navbar {
    background-color: var(--color-black);
    padding: 0.5rem 0;
    position: sticky;
    top: 0;
    z-index: 1000;
    border-bottom: 1px solid var(--color-accent);
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
  }

  .navbar__container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .navbar__brand {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
  }
  .navbar__brand img {
    width: 77px;
    height: 77px;
    object-fit: contain;
    padding: 4px;
    background: rgba(255, 255, 255, 0.03);
    border-radius: var(--radius-md);
    transition: transform 0.3s ease;
  }
  .navbar__brand:hover img {
    transform: scale(1.1);
  }
  .navbar__title {
    background: linear-gradient(
      90deg,
      #fdf6ec 30%,
      #fdba74 50%,
      #f97316 60%,
      #fdf6ec 75%
    );
    background-size: 300% auto;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: name-shimmer 22s linear infinite;
  }
  .navbar__title span {
    color: var(--color-brand-marron);
    -webkit-text-fill-color: var(--color-brand-marron);
  }

  .navbar__menu {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .navbar__list {
    display: flex;
    list-style: none;
    gap: 2rem;
    margin-left: 2rem;
  }
  .navbar__link {
    color: var(--color-brand-orange);
    font-weight: 700;
    text-decoration: none;
    font-size: var(--text-base);
    transition: color var(--transition-base);
    position: relative;
  }
  .navbar__link:hover {
    color: var(--color-white);
  }
  .navbar__link:focus {
    outline: 2px solid var(--color-brand-orange);
    outline-offset: 2px;
  }
  .navbar__link:visited {
    color: var(--color-brand-orange);
  }
  .navbar__link:active {
    color: var(--color-white);
  }
  .navbar__link::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 2px;
    background-color: var(--color-brand-orange);
    transition: width 0.3s ease;
    transform: translateX(-50%);
  }
  .navbar__link:hover::after {
    width: 80%;
  }

  .navbar__right-group {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-left: auto;
  }
  .navbar__lang {
    display: flex;
    gap: 0.5rem;
    color: var(--color-white);
    font-weight: bold;
    margin-left: 1.5rem;
  }
  .navbar__lang a {
    color: var(--color-white);
    text-decoration: none;
  }
  .navbar__lang a:hover {
    color: var(--color-brand-orange);
    text-decoration: underline;
  }
  .navbar__lang a:focus {
    outline: 2px solid var(--color-brand-orange);
    outline-offset: 2px;
  }
  .navbar__lang a:visited {
    color: var(--color-white);
  }
  .navbar__lang a:active {
    color: var(--color-brand-orange);
  }

  .navbar__toggle {
    display: none;
    background: none;
    padding: 0.5rem;
    cursor: pointer;
    border: 2px solid var(--color-brand-orange);
    border-radius: 4px;
    box-shadow: 3px 3px 0px var(--color-brand-orange);
    transition: transform 0.1s ease;
  }
  .navbar__toggle:active {
    transform: translate(2px, 2px);
    box-shadow: 1px 1px 0px var(--color-brand-orange);
  }
  .toggle__bar {
    display: block;
    width: 25px;
    height: 3px;
    background: var(--color-brand-orange);
    margin: 4px 0;
  }

  @media (max-width: 768px) {
    /* Muestra hamburguesa en móvil */
    .navbar__toggle {
      display: flex;
      flex-direction: column;
    }

    .navbar__menu {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      width: 100%;
      background: var(--color-black);
      flex-direction: column;
      padding: 1rem 0;
    }

    .navbar__menu.is-open {
      display: flex;
      flex-direction: column;
    }

    .navbar__list {
      flex-direction: column;
      align-items: center;
      margin-left: 0;
      gap: 1.5rem;
    }
  }
  @media (max-width: 300px) {
    .navbar__toggle {
      display: flex;
    }
    .navbar__menu {
      padding: var(--space-4);
      text-align: center;
    }
  }
</style>

<script>
  const toggle = document.querySelector(".navbar__toggle");
  const menu = document.getElementById("navbar-menu");
  const links = document.querySelectorAll(".navbar__link");

  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const isExpanded = menu.classList.toggle("is-open");
      toggle.setAttribute("aria-expanded", isExpanded.toString());
    });

    links.forEach((link) => {
      link.addEventListener("click", () => {
        menu.classList.remove("is-open");
        toggle.setAttribute("aria-expanded", "false");
      });
    });
  }
</script>
