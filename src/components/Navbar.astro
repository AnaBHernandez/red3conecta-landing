---
import t from "../i18n/ca.json";
---

<nav class="navbar" aria-label="Navegació principal">
  <div class="navbar__container">
    <a href="/" class="navbar__logo"
      ><!-- Logo integrado desde /public/Modelo_B.png -->
      <img
        src="/Modelo_B.png"
        alt="Logotip de Red3Conecta"
        width="90"
        height="85"
        loading="eager"
      />
    </a>
    <button
      class="navbar__toggle"
      aria-expanded="false"
      aria-label="Obrir menú de navegació"
    >
      <span class="toggle__bar"></span>
      <span class="toggle__bar"></span>
      <span class="toggle__bar"></span>
    </button>

    <div class="navbar__menu">
      <ul class="navbar__list">
        <li><a href="#why" class="navbar__link">{t.nav.why}</a></li>
        <li>
          <a href="#challenges" class="navbar__link">{t.nav.challenges}</a>
        </li>
        <li><a href="#ally" class="navbar__link">{t.nav.ally}</a></li>
        <li><a href="#ecosystem" class="navbar__link">{t.nav.ecosystem}</a></li>
      </ul>
    </div>
  </div>
</nav>

<style>
  .navbar {
    position: sticky;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    background: linear-gradient(to right, rgb(255, 167, 112), rgb(255, 200, 160));
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
     padding: var(--space-4, 16px) clamp(16px, 4vw, 48px);
  }

 .navbar__container {
  display: flex;
  justify-content: center;  /* ← centra todo */
  align-items: center;
  gap: clamp(24px, 5vw, 80px); /* ← espacio entre logo y links */
  width: 100%;
  max-width: 100%;
  margin: 0 auto;
  box-sizing: border-box;
}

  .navbar__logo {
    font-size: var(--text-md, 1.25rem);
    font-weight: 700;
    text-decoration: none;
    color: var(--color-black, #000000);
  }

  .logo__accent {
    color: var(--color-light-brown, #edcfa6);
  }

  .navbar__list {
  display: flex;
  list-style: none;
  gap: clamp(10px, 2vw, 24px); /* ← gap fluido más contenido */
  margin: 0;
  padding: 0;
}

  .navbar__link,
  .navbar__link:visited {
    text-decoration: none !important;
    color: var(--color-black, #000000) !important;
   font-size: clamp(0.75rem, 1vw, 0.95rem); /* más agresivo */
   white-space: nowrap;
    font-weight: 500;
    transition: color var(--transition-fast, 150ms ease);
  }

  .navbar__link:hover {
    color: var(--color-light-brown, #edcfa6) !important;
  }

  .navbar__link:active {
    color: var(--color-black, #000000);
  }

  .navbar__menu {
    display: flex;
    align-items: center;
  }

  .navbar__toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    flex-direction: column;
    gap: 4px;
    padding: var(--space-1, 4px);
  }

  .toggle__bar {
    width: 24px;
    height: 3px;
    background-color: var(--color-black, #000000);
  }

  @media (max-width: 768px) {
    .navbar__toggle {
      display: flex;
    }
    .navbar__list {
      flex-direction: column;
      gap: var(--space-4, 16px);
    }
  }
</style>
