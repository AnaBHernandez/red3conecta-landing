---
import t from "../i18n/ca.json";
---

<nav class="navbar" aria-label="Navegació principal">
  <div class="navbar__container">
    <a href="/" class="navbar__logo">
      <img
        src="/Modelo_B.png"
        alt="Inici de Red3Conecta"
        width="111"
        height="111"
      />
    </a>

    <button
      class="navbar__toggle"
      aria-expanded="false"
      aria-label="Obrir menú"
    >
      <span class="toggle__bar"></span>
      <span class="toggle__bar"></span>
      <span class="toggle__bar"></span>
    </button>

    <div class="navbar__menu" id="navbar-menu">
      <ul class="navbar__list">
        <li><a href="#why" class="navbar__link">{t.nav.why}</a></li>
        <li>
          <a href="#challenges" class="navbar__link">{t.nav.challenges}</a>
        </li>
        <li><a href="#ally" class="navbar__link">{t.nav.ally}</a></li>
        <li><a href="#ecosystem" class="navbar__link">{t.nav.ecosystem}</a></li>
        <span class="footer__divider-name">Red<em>3</em>Conecta</span>
      </ul>
    </div>
  </div>
</nav>

<style>
  .navbar {
    background-color: var(--color-black);
    padding: 1rem 2rem;
    position: sticky;
    top: 0;
    z-index: 1000;
    border-bottom: var(--border-thin) solid var(--color-accent);
    backdrop-filter: blur(10px);
  }

  .navbar__container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1100px;
    margin: 0 auto;
  }

  .navbar__list {
    display: flex;
    list-style: none;
    gap: 2rem;
    margin: 0;
    padding: 0;
  }

  .navbar__link {
    text-decoration: none;
    color: var(--color-accent);
    font-weight: 700;
    transition: color var(--transition-base);
  }

  .navbar__link:visited {
    color: var(--color-accent);
  }
  .navbar__link:active {
    color: var(--color-highlight);
  }
  .navbar__link:hover {
    color: var(--color-white);
  }

  .navbar__toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
  }

  .toggle__bar {
    display: block;
    width: 25px;
    height: 3px;
    background: var(--color-accent);
    margin: 4px 0;
  }

  @media (max-width: 768px) {
    .navbar__toggle {
      display: flex;
      flex-direction: column;
    }

    .navbar__menu {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--color-black);
      padding: 2rem;
      border-bottom: 1px solid var(--color-accent);
    }

    .navbar__menu.is-open {
      display: flex !important;
      flex-direction: column;
    }

    .navbar__list {
      flex-direction: column;
      gap: 1.5rem;
      align-items: center;
    }
  }
</style>

<script>
  const toggle = document.querySelector(".navbar__toggle");
  const menu = document.getElementById("navbar-menu");

  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const isExpanded = menu.classList.toggle("is-open");
      toggle.setAttribute("aria-expanded", String(isExpanded));
    });
  }
</script>
