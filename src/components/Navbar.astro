---
import t from "../i18n/ca.json";
---

<nav class="navbar" aria-label="Navegació principal">
  <div class="navbar__container">
    <a href="/" class="navbar__logo">
      <img src="/Modelo_B.png" alt="Logotip" width="111" height="111" />
    </a>

    <button
      class="navbar__toggle"
      aria-expanded="false"
      aria-label="Obrir menú"
    >
      <span class="toggle__bar"></span>
      <span class="toggle__bar"></span>
      <span class="toggle__bar"></span>
    </button>

    <div class="navbar__menu" id="navbar-menu">
      <ul class="navbar__list">
        <li><a href="#why" class="navbar__link">{t.nav.why}</a></li>
        <li>
          <a href="#challenges" class="navbar__link">{t.nav.challenges}</a>
        </li>
        <li><a href="#ally" class="navbar__link">{t.nav.ally}</a></li>
        <li><a href="#ecosystem" class="navbar__link">{t.nav.ecosystem}</a></li>
      </ul>
    </div>
  </div>
</nav>

<style>
  .navbar {
    background-color: #1a0d04;
    padding: 1rem 2rem;
    position: sticky;
    top: 0;
    z-index: 1000;
    border-bottom: 1px solid rgba(249, 115, 22, 0.22);
  }

  .navbar__container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1100px;
    margin: 0 auto;
  }

  .navbar__list {
    display: flex;
    list-style: none;
    gap: 2rem;
    margin: 0;
    padding: 0;
  }

  .navbar__link {
    text-decoration: none;
    color: #f97316;
    font-weight: 700;
    font-size: 0.9rem;
    transition: color 200ms;
  }
  .navbar__link:hover {
    color: #ffffff;
  }

  .navbar__toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
  }
  .toggle__bar {
    display: block;
    width: 25px;
    height: 3px;
    background: #f97316;
    margin: 4px 0;
  }

  @media (max-width: 768px) {
    .navbar__toggle {
      display: flex;
      flex-direction: column;
    }

    .navbar__menu {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: #1a0d04;
      padding: 2rem;
      border-bottom: 1px solid #f97316;
    }
    .navbar__menu.is-open {
      display: flex !important;
    }
    .navbar__list {
      flex-direction: column;
      gap: 1.5rem;
      align-items: center;
    }
  }
</style>

<script>
  // Astro carga scripts al cargar la página
  const toggle = document.querySelector(".navbar__toggle");
  const menu = document.getElementById("navbar-menu");

  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      menu.classList.toggle("is-open");
      const isExpanded = menu.classList.contains("is-open");
      toggle.setAttribute("aria-expanded", String(isExpanded));
    });
  }
</script>
