---
// src/components/Sectioneight.astro
import i18n from "../i18n/ca.json";
const s8 = (i18n as any).section8;
---

<section class="section8" aria-labelledby="s8-heading">
  <div class="container">
    <div class="cta-card" id="s8-card">

      <!-- Esquinas animadas -->
      <span class="corner corner--tl" aria-hidden="true"></span>
      <span class="corner corner--tr" aria-hidden="true"></span>
      <span class="corner corner--bl" aria-hidden="true"></span>
      <span class="corner corner--br" aria-hidden="true"></span>

      <h2 id="s8-heading" class="cta-title">{s8.title}</h2>
      <p class="cta-intro">{s8.intro}</p>

      <div class="cta-buttons">
        {
          s8.ctas.map((cta: any, index: number) => (
            <a
              href={index === 0 ? "https://form.asana.com/?k=Xi-unyAAA4uXYNzBzx5bmA&d=1111991690250694" : "#"}
              target={index === 0 ? "_blank" : undefined}
              rel={index === 0 ? "noopener noreferrer" : undefined}
              class:list={[
                "cta-btn",
                index === 0 ? "cta-btn--primary" : "cta-btn--secondary",
              ]}
              aria-label={cta.label}
            >
              <span class="cta-btn__arrow" aria-hidden="true">
                {cta.arrow}
              </span>
              <span class="cta-btn__text">
                <strong class="cta-btn__label">{cta.label}</strong>
                <span class="cta-btn__desc">{cta.description}</span>
              </span>
            </a>
          ))
        }
      </div>
    </div>

    <footer class="section-footer">
      <p class="contact-note">{s8.contactNote}</p>
      <p class="footer-credits">{s8.footer}</p>
    </footer>
  </div>
</section>

<style>
  .section8 {
    --s-bg-main: #e8d5b7;
    --s-bg-page: #faf7f2;
    --s-text-primary: #2c1810;
    --s-text-secondary: #5c3d2e;
    --s-text-muted: #8b7355;
    --s-accent: #8b6914;
    --s-border: #2c1810;
    --s-corner: #8b6914;
    --s-corner-size: 22px;
    --s-corner-thick: 2.5px;

    background-color: var(--s-bg-page);
    padding: clamp(3rem, 8vw, 6rem) 0;
    perspective: 1200px;
  }

  .container {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 clamp(1rem, 5vw, 2.5rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
  }

  /* ── Card ── */
  .cta-card {
    background-color: var(--s-bg-main);
    border-radius: 12px;
    padding: clamp(2.5rem, 7vw, 5rem) clamp(2rem, 6vw, 5rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    text-align: center;
    width: 100%;
    position: relative;
    transform-origin: top center;
    opacity: 0;
    transform: rotateX(-18deg) translateY(-24px) scale(0.97);
    transition: none;
  }

  .cta-card.is-visible {
    animation: cardDrop 0.75s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  /* ── Corner brackets ── */
  .corner {
    position: absolute;
    width: var(--s-corner-size);
    height: var(--s-corner-size);
    border-color: var(--s-corner);
    border-style: solid;
    border-width: 0;
    opacity: 0;
  }

  .corner--tl {
    top: 14px;
    left: 14px;
    border-top-width: var(--s-corner-thick);
    border-left-width: var(--s-corner-thick);
    border-top-left-radius: 3px;
  }

  .corner--tr {
    top: 14px;
    right: 14px;
    border-top-width: var(--s-corner-thick);
    border-right-width: var(--s-corner-thick);
    border-top-right-radius: 3px;
  }

  .corner--bl {
    bottom: 14px;
    left: 14px;
    border-bottom-width: var(--s-corner-thick);
    border-left-width: var(--s-corner-thick);
    border-bottom-left-radius: 3px;
  }

  .corner--br {
    bottom: 14px;
    right: 14px;
    border-bottom-width: var(--s-corner-thick);
    border-right-width: var(--s-corner-thick);
    border-bottom-right-radius: 3px;
  }

  /*
   * Estrategia de dos fases:
   * 1. Slide-in (forwards): entra desde su dirección, termina en opacity:1 translate(0,0)
   * 2. Breathe (infinite): arranca justo cuando termina el slide-in, mueve 2-3px de vuelta
   *    El `animation-fill-mode: forwards` del slide garantiza que opacity quede en 1
   *    antes de que empiece el breathe.
   */
  .cta-card.is-visible .corner--tl {
    animation:
      cornerSlideInTL  0.45s cubic-bezier(0.22, 1, 0.36, 1) 0.65s forwards,
      cornerBreatheTL  4s   ease-in-out                      1.15s infinite;
  }

  .cta-card.is-visible .corner--tr {
    animation:
      cornerSlideInTR  0.45s cubic-bezier(0.22, 1, 0.36, 1) 0.70s forwards,
      cornerBreatheTR  4s   ease-in-out                      1.20s infinite;
  }

  .cta-card.is-visible .corner--bl {
    animation:
      cornerSlideInBL  0.45s cubic-bezier(0.22, 1, 0.36, 1) 0.72s forwards,
      cornerBreatheBL  4s   ease-in-out                      1.25s infinite;
  }

  .cta-card.is-visible .corner--br {
    animation:
      cornerSlideInBR  0.45s cubic-bezier(0.22, 1, 0.36, 1) 0.75s forwards,
      cornerBreatheBR  4s   ease-in-out                      1.30s infinite;
  }

  /* ── Keyframes ── */
  @keyframes cardDrop {
    0%   { opacity: 0; transform: rotateX(-18deg) translateY(-24px) scale(0.97); }
    60%  { opacity: 1; transform: rotateX(3deg) translateY(4px) scale(1.005); }
    100% { opacity: 1; transform: rotateX(0deg) translateY(0) scale(1); }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes cornerSlideInTL {
    from { opacity: 0; transform: translate(-6px, -6px); }
    to   { opacity: 1; transform: translate(0, 0); }
  }
  @keyframes cornerSlideInTR {
    from { opacity: 0; transform: translate(6px, -6px); }
    to   { opacity: 1; transform: translate(0, 0); }
  }
  @keyframes cornerSlideInBL {
    from { opacity: 0; transform: translate(-6px, 6px); }
    to   { opacity: 1; transform: translate(0, 0); }
  }
  @keyframes cornerSlideInBR {
    from { opacity: 0; transform: translate(6px, 6px); }
    to   { opacity: 1; transform: translate(0, 0); }
  }

  /* Movimiento "respiración" — 2-3px hacia la dirección de cada esquina */
  @keyframes cornerBreatheTL {
    0%, 100% { opacity: 1; transform: translate(0, 0); }
    50%       { opacity: 0.7; transform: translate(-3px, -3px); }
  }
  @keyframes cornerBreatheTR {
    0%, 100% { opacity: 1; transform: translate(0, 0); }
    50%       { opacity: 0.7; transform: translate(3px, -3px); }
  }
  @keyframes cornerBreatheBL {
    0%, 100% { opacity: 1; transform: translate(0, 0); }
    50%       { opacity: 0.7; transform: translate(-3px, 3px); }
  }
  @keyframes cornerBreatheBR {
    0%, 100% { opacity: 1; transform: translate(0, 0); }
    50%       { opacity: 0.7; transform: translate(3px, 3px); }
  }

  /* ── Content fade-up ── */
  .cta-title,
  .cta-intro,
  .cta-buttons {
    opacity: 0;
    transform: translateY(12px);
  }

  .cta-card.is-visible .cta-title {
    animation: fadeUp 0.5s ease 0.3s forwards;
  }
  .cta-card.is-visible .cta-intro {
    animation: fadeUp 0.5s ease 0.44s forwards;
  }
  .cta-card.is-visible .cta-buttons {
    animation: fadeUp 0.5s ease 0.58s forwards;
  }

  /* ── Typography ── */
  .cta-title {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 700;
    color: var(--s-text-primary);
    margin: 0;
    max-width: 700px;
  }

  .cta-intro {
    font-size: clamp(0.95rem, 2.2vw, 1.0625rem);
    color: var(--s-text-secondary);
    line-height: 1.75;
    margin: 0;
    max-width: 600px;
  }

  /* ── Buttons ── */
  .cta-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    justify-content: center;
    width: 100%;
  }

  .cta-btn {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1.1rem 1.75rem;
    border: 2px solid var(--s-border);
    border-radius: 8px;
    text-decoration: none;
    color: var(--s-text-primary);
    flex: 1;
    min-width: 240px;
    max-width: 340px;
    position: relative;
    overflow: hidden;
    transition:
      transform 0.28s cubic-bezier(0.34, 1.4, 0.64, 1),
      background 0.2s ease,
      box-shadow 0.28s ease;
  }

  .cta-btn--primary {
    background-color: rgba(44, 24, 16, 0.07);
  }

  .cta-btn::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      115deg,
      transparent 30%,
      rgba(255, 255, 255, 0.3) 50%,
      transparent 70%
    );
    transform: translateX(-120%);
    transition: transform 0.5s ease;
    pointer-events: none;
  }

  .cta-btn:hover::after {
    transform: translateX(120%);
  }

  .cta-btn:hover {
    background-color: rgba(44, 24, 16, 0.13);
    transform: translateY(-4px) rotateX(4deg) scale(1.02);
    box-shadow: 0 8px 20px rgba(44, 24, 16, 0.12);
  }

  .cta-btn__arrow {
    color: var(--s-accent);
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 1px;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .cta-btn:hover .cta-btn__arrow {
    transform: translateX(5px) scale(1.15);
  }

  .cta-btn__label {
    font-weight: 700;
    display: block;
  }

  .cta-btn__desc {
    font-size: 0.8125rem;
    color: var(--s-text-secondary);
    display: block;
  }

  /* ── Footer ── */
  .section-footer {
    text-align: center;
    color: var(--s-text-muted);
    font-style: italic;
    font-size: 0.875rem;
  }
</style>

<script>
  const card = document.getElementById('s8-card');
  if (card) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          card.classList.add('is-visible');
          observer.disconnect();
        }
      },
      { threshold: 0.2 }
    );
    observer.observe(card);
  }
</script>