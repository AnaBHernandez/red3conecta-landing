---
const { t } = Astro.props;
---

<div class="bk_section">
  <div class="container-alpha">
    <div class="alpha_tittle">
      <h2>{t.section5.title}</h2>
      <p class="container-alpha__subtitle">{t.section5.subtitle}</p>
    </div>
  </div>

  <div class="cards-row">
    {
      t.section5.cards_small.map((card: any) => (
        <div class="card-small" data-card-small>
          <button class="card-small__button" aria-expanded="false">
            <img src={card.icon} alt={card.icon_alt} class="card-icon" />
            <h3>{card.title}</h3>
            <!-- PILL CTA -->
            <span class="card__cta">
              <span class="card__cta-text">{t.section5.cta_toggle}</span>
              <span class="card__flecha">▾</span>
            </span>
          </button>
          <div class="card-small__body">
            <p>{card.desc}</p>
          </div>
        </div>
      ))
    }
  </div>

  <div class="cards-column">
    {
      t.section5.cards_wide.map((card: any) => (
        <div class="card-wide" data-card-wide>
          <button class="card-wide__button" aria-expanded="false">
            <img src={card.icon} alt={card.icon_alt} class="card-icon" />
            <div class="card-wide__header">
              <h3>{card.title}</h3>
              <!-- PILL CTA -->
              <span class="card__cta">
                <span class="card__cta-text">{t.section5.cta_toggle}</span>
                <span class="card__flecha">▾</span>
              </span>
            </div>
          </button>
          <div class="card-wide__body">
            <p>{card.desc}</p>
          </div>
        </div>
      ))
    }
  </div>
</div>

<style>
  .bk_section{
    background-color: var(--color-surface-raised);
    margin-bottom: var(--space-20);
    margin-top: var(--space-20);
  }
  .container-alpha {
    background-color: var(--color-surface);
    
    margin-bottom: 0;
    padding: 2rem 1.5rem;
    border-radius: 1rem;
  }

  .container-alpha h2 {
    color: var(--color-primary);
    text-decoration-line: underline;
  }

  .container-alpha__subtitle {
    color: var(--color-black);
  }

  .alpha_tittle {
    padding: 1rem 1.5rem;
   background: linear-gradient(170deg,  #f7e7d0ce 15%, #ffbc7a 70%);
    border-radius: 1rem;
    width: 100%;

    border-width: 8px;
    margin-bottom: var(--space-1);
  }

  .cards-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1.5rem;
    border-radius: 1.5rem;
    padding: 1rem 1.5rem;
    margin: var(--space-12);
    margin-top: 0;
    align-items: flex-start;
    background-color: var(--color-background);
  }

  .card-small {
    flex: 1;
    background-color: var(--color-surface-raised);
    border-radius: 1rem;
    overflow: hidden;
    outline: 2px solid transparent;
    margin: 1px;
    padding: 10px;
    transition:
      box-shadow 0.25s ease,
      var(--color-border) 0.25s ease,
      outline 0.2s ease;
      max-width: 500px;
      outline: 2px solid rgba(185, 102, 0, 0.201);
  }

  .card-small:hover {
    box-shadow: var(--shadow-md);
    background-color:rgba(255, 202, 137, 0.148);
    outline: 2px solid var(--color-border);
  }

  .card-small__button {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding: 1.2rem 1rem;
    background: none;
    border: none;
   cursor: pointer;
    text-align: center;
    border-radius: 1rem;
    transition: background 0.2s ease;
  }

  .card-small__button:focus-visible {
    outline: 2px solid var(--color-border);
  }

  .card-small__button h3 {
    margin: 0;
    font-size: 0.95rem;
    color: var(--color-black);
    transition: font-size 0.3s ease, opacity 0.3s ease;
  }

  .card-small--abierta .card-small__button h3 {
    font-size: 0.8rem;
    opacity: 0.7;
  }

  .card-small__body {
    max-height: 0;
    overflow: hidden;
    padding: 0 1rem;
    transition: max-height 0.4s ease, padding 0.4s ease;
  }

  .card-small--abierta .card-small__body {
    max-height: 200px;
    padding: 0 1rem 1rem;
    border-top: 1px solid rgba(0, 0, 0, 0.07);
  }

  .card-small__body p {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--color-black);
    text-align: left;
    opacity: 0;
    transform: translateY(-6px);
    transition: opacity 0.3s ease 0.15s, transform 0.3s ease 0.15s;
  }

  .card-small--abierta .card-small__body p {
    opacity: 1;
    transform: translateY(0);
  }

  .cards-column {
    display: flex;
    flex-direction: row;
    gap: 1.5rem;
    align-items: flex-start;
    padding: var(--space-3);
    margin-bottom: var(--space-12);
    width: 100%;
    box-sizing: border-box;
  }

  .card-wide {
   background-color: ; var(--color-surface-raised);
    border-radius: 2rem;
    overflow: hidden;
    flex: 1;
    outline: 2px solid transparent;
    transition:
      box-shadow 0.25s ease,
      var(--color-border) 0.25s ease,
      outline 0.2s ease;
          outline: 2px solid rgba(220, 121, 0, 0.055);
  }

  .card-wide:hover {
    box-shadow: var(--shadow-md);
    outline: 2px solid var(--color-border);
    background-color:rgba(255, 202, 137, 0.148);
   
  }

  .card-wide__button {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1.2rem;
    width: 100%;
    padding: 1.2rem 1.5rem;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    border-radius: 1rem;
    transition: background 0.2s ease;
  }

  .card-wide__button:focus-visible {
    outline: 2px solid var(--color-border);
  }

  .card-wide__header {
    display: flex;
    flex: 1;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .card-wide__header h3 {
    margin: 0;
    font-size: 1rem;
    color: var(--color-black);
    transition: font-size 0.3s ease, opacity 0.3s ease;
  }

  .card-wide--abierta .card-wide__header h3 {
    font-size: 0.88rem;
    opacity: 0.7;
  }

  /* cuerpo cerrado */
  .card-wide__body {
    max-height: 0;
    overflow: hidden;
    padding: 0 1.5rem;
    transition: max-height 0.4s ease, padding 0.4s ease;
  }

  /* cuerpo abierto */
  .card-wide--abierta .card-wide__body {
    max-height: 200px;
    padding: 0.25rem 1.5rem 1.2rem 4.5rem;
    border-top: 1px solid rgba(0, 0, 0, 0.07);
  }

  .card-wide__body p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-black);
    opacity: 0;
    transform: translateX(-8px);
    transition: opacity 0.3s ease 0.15s, transform 0.3s ease 0.15s;
  }

  .card-wide--abierta .card-wide__body p {
    opacity: 1;
    transform: translateX(0);
  }

  .card__cta {
    display: flex;
    align-items: center;
    gap: 4px;
    background: rgba(0, 0, 0, 0.07);
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 0.75rem;
    color: var(--color-black);
    flex-shrink: 0;
    transition: background 0.2s ease;
  }

  .card-small__button:hover .card__cta,
  .card-wide__button:hover .card__cta {
    background: rgba(0, 0, 0, 0.13);
  }

  .card-small--abierta .card__cta-text,
  .card-wide--abierta .card__cta-text {
    display: none;
  }

  .card__flecha {
    font-size: 1rem;
    color: var(--color-black);
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .card-small--abierta .card__flecha,
  .card-wide--abierta .card__flecha {
    transform: rotate(180deg);
  }

  .card-icon {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
    transition: width 0.3s ease, height 0.3s ease, opacity 0.3s ease;
  }

  .card-small--abierta .card-icon,
  .card-wide--abierta .card-icon {
    width: 36px;
    height: 36px;
    opacity: 0.6;
  }

  .bk_section {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 0 var(--space-2);
    background-color: var(--color-surface);
    border-top: var(--space-12);
  }
</style>

<script>
  const tarjetasSmall = document.querySelectorAll("[data-card-small]");

  tarjetasSmall.forEach((tarjeta) => {
    const boton = tarjeta.querySelector(".card-small__button");

    boton?.addEventListener("click", () => {
      const estaAbierta = tarjeta.classList.contains("card-small--abierta");

      tarjetasSmall.forEach((t) => {
        t.classList.remove("card-small--abierta");
        t.querySelector(".card-small__button")?.setAttribute("aria-expanded", "false");
      });

      if (!estaAbierta) {
        tarjeta.classList.add("card-small--abierta");
        boton.setAttribute("aria-expanded", "true");
      }
    });
  });

  const tarjetasWide = document.querySelectorAll("[data-card-wide]");

  tarjetasWide.forEach((tarjeta) => {
    const boton = tarjeta.querySelector(".card-wide__button");

    boton?.addEventListener("click", () => {
      const estaAbierta = tarjeta.classList.contains("card-wide--abierta");

      tarjetasWide.forEach((t) => {
        t.classList.remove("card-wide--abierta");
        t.querySelector(".card-wide__button")?.setAttribute("aria-expanded", "false");
      });

      if (!estaAbierta) {
        tarjeta.classList.add("card-wide--abierta");
        boton.setAttribute("aria-expanded", "true");
      }
    });
  });
</script>