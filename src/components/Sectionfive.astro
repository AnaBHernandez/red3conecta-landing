---
import t from "../i18n/ca.json";
---
<div class="bk_section"> 
<div class="container-alpha">
  <div class="alpha_tittle">
    <h2>{t.section5.title}</h2>
    <p class="container-alpha__subtitle">{t.section5.subtitle}</p>
  </div>
</div>

<div class="cards-row">
  {
    t.section5.cards_small.map((card) => (
      <div class="card-small" data-card-small>
        <button class="card-small__button" aria-expanded="false">
          <img src={card.icon} alt={card.icon_alt} class="card-icon" />
          <h3>{card.title}</h3>
          <span class="card__flecha">▾</span>
        </button>
        <div class="card-small__body">
          <p>{card.desc}</p>
        </div>
      </div>
    ))
  }
</div>

<div class="cards-column">
  {
    t.section5.cards_wide.map((card) => (
      <div class="card-wide" data-card-wide>
        <button class="card-wide__button" aria-expanded="false">
          <img src={card.icon} alt={card.icon_alt} class="card-icon" />
          <div class="card-wide__header">
            <h3>{card.title}</h3>
            <span class="card__flecha">▾</span>
          </div>
        </button>
        <div class="card-wide__body">
          <p>{card.desc}</p>
        </div>
      </div>
    ))
  }
</div>
</div>
<style>
  .container-alpha {
    background-color: rgba(233, 150, 122, 0.045);
    margin-top: var(--space-1);
    margin-bottom: 0;
    padding: 2rem 1.5rem;
    border-radius: 1rem;
  }

  .container-alpha h2 {
    color: var(--color-black);
  }

  .container-alpha__subtitle {
    color: var(--color-black);
  }
  .alpha_tittle {
    padding: 2rem 1.5rem;
    background-color: var(--color-peach-warm);
    border-radius: 1rem;
    margin-bottom: var(--space-2);
    width: 100%;

    border-color: var(--color-peach-soft);
    border-width: 5px;
    border-style: solid;
  }

  /* ---  CARDS --- */
  .cards-row {
    display: flex;
    flex-direction: row;
    gap: 2rem;
    background-color: rgba(245, 194, 117, 0.419);
    border-radius: var(--space-20);
    flex: 1;
    overflow: hidden;
    transition:
      box-shadow 0.25s ease,
      background-color 0.35s ease;
    padding: 1.5rem;
    margin: var(--space-2);
    margin-top: 0;
  }

  .card-small:hover {
    box-shadow: var(--shadow-md);
    background-color: rgba(255, 81, 0, 0.189);
    border-radius: 1rem;
  }

  .card-small__button {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding: 1.2rem 1rem;
    background: none;
    border: none;
    cursor: pointer;
    text-align: center;

    transition: background 0.2s ease;
  }

  .card-small__button h3 {
    margin: 0;
    font-size: 0.95rem;
    color: var(--color-black);
    transition:
      font-size 0.3s ease,
      opacity 0.3s ease;
  }

  .card-small--abierta .card-small__button h3 {
    font-size: 0.8rem;
    opacity: 0.7;
  }

  /* cuerpo cerrado */
  .card-small__body {
    max-height: 0;
    overflow: hidden;
    padding: 0 1rem;
    transition:
      max-height 0.4s ease,
      padding 0.4s ease;
      border-bottom: var(--space-12);
  }

  /* cuerpo abierto */
  .card-small--abierta .card-small__body {
    max-height: 200px;
    padding: 0 1rem 1rem;
    border-top: 1px solid rgba(0, 0, 0, 0.07);
  }

  .card-small__body p {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--color-black);
    text-align: left;
    opacity: 0;
    transform: translateY(-6px);
    transition:
      opacity 0.3s ease 0.15s,
      transform 0.3s ease 0.15s;
  }

  .card-small--abierta .card-small__body p {
    opacity: 1;
    transform: translateY(0);
  }

  .cards-column {
    display: flex;
    flex-direction: row;
    gap: 1rem;
    align-items: flex-start;
    margin-bottom: var(--space-12);
  }

  .card-wide {
    background-color: var(--color-cream-light);
    border-radius: 1rem;
    overflow: hidden;
    transition:
      box-shadow 0.25s ease,
      background-color 0.25s ease;
    max-width: 400px;
  }

  .card-wide:hover {
    box-shadow: var(--shadow-md);
    background-color: var(--color-peach-soft);
  }

  .card-wide__button {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1.2rem;
    width: 100%;
    padding: 1.2rem 1.5rem;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: background 0.2s ease;
    background-color: var(--color-cream-light);
  }

  .card-wide__header {
    display: flex;
    flex: 1;
    align-items: center;
    justify-content: space-between;
  }

  .card-wide__header h3 {
    margin: 0;
    font-size: 1rem;
    color: var(--color-black);
    transition:
      font-size 0.3s ease,
      opacity 0.3s ease;
  }

  .card-wide--abierta .card-wide__header h3 {
    font-size: 0.88rem;
    opacity: 0.7;
  }

  /* cuerpo cerrado */
  .card-wide__body {
    max-height: 0;
    overflow: hidden;
    padding: 0 1.5rem;
    transition:
      max-height 0.4s ease,
      padding 0.4s ease;
  }

  /* cuerpo abierto */
  .card-wide--abierta .card-wide__body {
    max-height: 200px;
    padding: 0.25rem 1.5rem 1.2rem 4.5rem; /* sangría alineada con el texto del header */
    border-top: 1px solid rgba(0, 0, 0, 0.07);
  }

  .card-wide__body p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-black);
    opacity: 0;
    transform: translateX(-8px);
    transition:
      opacity 0.3s ease 0.15s,
      transform 0.3s ease 0.15s;
    background-color: rgba(255, 127, 80, 0.129);
    height: 100px;
  }

  .card-wide--abierta .card-wide__body p {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── COMÚN ── */
  .card-icon {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
    transition:
      width 0.3s ease,
      height 0.3s ease,
      opacity 0.3s ease;
  }

  .card-small--abierta .card-icon,
  .card-wide--abierta .card-icon {
    width: 36px;
    height: 36px;
    opacity: 0.6;
  }

  .card__flecha {
    font-size: 1rem;
    color: var(--color-black);
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .card-small--abierta .card__flecha,
  .card-wide--abierta .card__flecha {
    transform: rotate(180deg);
  }
  .bk_section {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 0 var(--space-2);
    background-color:rgba(255, 176, 119, 0.364);
    border-top:var(--space-12)
  }
</style>

<script>
  // ── Cards pequeñas — acordeón independiente ──
  const tarjetasSmall = document.querySelectorAll("[data-card-small]");

  tarjetasSmall.forEach((tarjeta) => {
    const boton = tarjeta.querySelector(".card-small__button");

    boton?.addEventListener("click", () => {
      const estaAbierta = tarjeta.classList.contains("card-small--abierta");

      // Cierra todas las small
      tarjetasSmall.forEach((t) => {
        t.classList.remove("card-small--abierta");
        t.querySelector(".card-small__button")?.setAttribute(
          "aria-expanded",
          "false",
        );
      });

      if (!estaAbierta) {
        tarjeta.classList.add("card-small--abierta");
        boton.setAttribute("aria-expanded", "true");
      }
    });
  });

  // ── Cards anchas — acordeón independiente ──
  const tarjetasWide = document.querySelectorAll("[data-card-wide]");

  tarjetasWide.forEach((tarjeta) => {
    const boton = tarjeta.querySelector(".card-wide__button");

    boton?.addEventListener("click", () => {
      const estaAbierta = tarjeta.classList.contains("card-wide--abierta");

      // Cierra todas las wide
      tarjetasWide.forEach((t) => {
        t.classList.remove("card-wide--abierta");
        t.querySelector(".card-wide__button")?.setAttribute(
          "aria-expanded",
          "false",
        );
      });

      if (!estaAbierta) {
        tarjeta.classList.add("card-wide--abierta");
        boton.setAttribute("aria-expanded", "true");
      }
    });
  });
</script>
