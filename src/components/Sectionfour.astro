---
import t from "../i18n/ca.json";
import Card from "./Card.astro";
---

<div class="container">
  <div class="container__header">
    <h2>{t.platform.title}</h2>
    <p>{t.platform.desc}</p>
  </div>

  <div class="container__blocs">
    <div class="bloc bloc--a">
      <div class="bloc__overlay"></div>
      <div class="bloc__content">
        <h3>{t.platform.bloc_a_title}</h3>
        <p class="bloc__tagline">{t.platform.bloc_a_tag}</p>
        <ul>
          {t.platform.bloc_a_list.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>

    <div class="bloc bloc--b">
      <div class="bloc__overlay"></div>
      <div class="bloc__content">
        <h3>{t.platform.bloc_b_title}</h3>
        <p class="bloc__tagline">{t.platform.bloc_b_tag}</p>
        <ul>
          {t.platform.bloc_b_list.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </div>

  <div class="container__casos">
    <h3 class="casos__titulo">{t.platform.casos_title}</h3>
    <div class="casos__grid">
      {t.platform.casos.map((caso) => (
        <Card
          icon={caso.icon}
          title={caso.title}
          description={caso.description}
          variant="caso"
        />
      ))}
    </div>
  </div>
</div>

<style>
  .container {
    background-color: var(--color-light-brown);
    display: flex;
    flex-direction: column;
    padding: 3rem;
    gap: 2.5rem;
  }

  /* HEADER */
  .container__header h2 {
    font-size: 1.8rem;
    color: var(--color-black);
    margin: 0 0 1rem 0;
  }

  .container__header p {
    color: #444;
    line-height: 1.6;
    margin: 0;
  }
  li{
    background: rgba(255, 255, 255, 0.15); 
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    backdrop-filter: blur(4px);
    font-weight:bolder;
  }

  /* BLOCS */
  .container__blocs {
    display: flex;
    flex-direction: row;
    gap: 2rem;
  }

  .bloc {
    position: relative;
    border-radius: 1rem;
    flex: 1;
    overflow: hidden;               /* recorta overlay e imagen */
    background-size: cover;
    background-position: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .bloc:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }
  .bloc--a {
    background-image: url("public/imagenes/social-team.jpg");
    border-left: 6px solid rgba(255, 127, 80, 0.646);
  }

  .bloc--b {
    background-image: url("public/imagenes/social-media.jpg");
    border-left: 6px solid rgba(255, 127, 80, 0.646);
  }
  .bloc__overlay {
  position: absolute;
  inset: 0;
  background: rgba(255, 255, 255, 0.08); 
  backdrop-filter: blur(2px);            
  z-index: 0;
}

  .bloc:hover .bloc__overlay {
    background: rgba(0, 0, 0, 0.38); 
  }
  .bloc__content {
   position: relative;
  z-index: 1;
  margin: 1.5rem;                       
  padding: 2rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  color: white;

  background: rgba(0, 0, 0, 0.35);      
  backdrop-filter: blur(12px);           
  -webkit-backdrop-filter: blur(12px);   
  border-radius: 1rem;
  border: 1px solid rgba(255, 255, 255, 0.15); 
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
  }
  .bloc__content h3 {
    margin: 0;
    color: white;
    font-size: 1.3rem;
  }

  .bloc__tagline {
    font-style: italic;
    color: rgba(255, 255, 255, 0.85);
    margin: 0;
  }

  .bloc ul {
    padding-left: 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin: 0;
  }

  .bloc li {
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.9);
  }

  .bloc__result {
    margin: 0;
    font-weight: bold;
    font-size: 0.9rem;
    color: white;
    background: rgba(255, 255, 255, 0.15); 
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    backdrop-filter: blur(4px);
  }

  /* CASOS */
  .container__casos {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .casos__titulo {
    margin: 0;
    color: var(--color-black);
    font-size: 1.3rem;
  }

  .casos__grid {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
</style>