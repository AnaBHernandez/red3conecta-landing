---
import t from "../i18n/ca.json";
import Card from "./Card.astro";
---

<div class="container">
  <div class="container__header">
    <h2>
      Red3Conecta: la infraestructura digital compartida del tercer sector.
    </h2>
    <p>
      Una plataforma web amb intel·ligència artificial conversacional i un
      catàleg centralitzat de recursos, dissenyada per als dos actors clau de
      qualsevol servei social: els professionals que acompanyen i les persones
      que necessiten suport.
    </p>
  </div>

  <!-- BLOC A Y BLOC B -->
  <div class="container__blocs">
    <div class="bloc bloc--a">
      <div class="bloc__overlay"></div>
      <div class="bloc__content">
        <h3>Per a professionals del tercer sector</h3>
        <p class="bloc__tagline">Menys temps gestionant. Més temps atenent.</p>
        <ul>
          <li>Catàleg de recursos validat, editable i actualitzat col·lectivament.</li>
          <li>Cercador intel·ligent amb recomanacions argumentades en segons.</li>
          <li>Filtres per tipologia, territori, perfil i requisits d'accés.</li>
          <li>Coordinació i derivació entre entitats àgil i traçable.</li>
          <li>Registre de consultes i aprenentatge continu.</li>
        </ul>
        <p class="bloc__result">
          Reducció de més del 50% del temps dedicat a cerques i coordinació manual.
        </p>
      </div>
    </div>

    <div class="bloc bloc--b">
      <div class="bloc__overlay"></div>
      <div class="bloc__content">
        <h3>Per a les persones ateses</h3>
        <p class="bloc__tagline">
          Accés clar. Sense barreres. Des de qualsevol dispositiu.
        </p>
        <ul>
          <li>Buscador simplificat amb llenguatge clar i accessible.</li>
          <li>Navegació guiada cap als recursos adaptats al seu perfil.</li>
          <li>Accessible des del mòbil, sense coneixements tecnològics avançats.</li>
        </ul>
        <p class="bloc__result">
          Millora de l'autonomia en la cerca de recursos i reducció de la
          dependència d'intermediaris.
        </p>
      </div>
    </div>
  </div>

  <!-- CASOS DE USO -->
  <div class="container__casos">
    <h3 class="casos__titulo">Casos d'ús concrets</h3>
    <div class="casos__grid">
      <Card
        icon="/icon-inertion-place.png"
        title="Professional d'inserció laboral"
        description="Una professional d&#39;una entitat d&#39;inserció laboral descriu el perfil d&#39;una persona en
llenguatge natural. Red3Conecta li retorna en segons els recursos del territori que
millor s&#39;adapten al cas — ex: formació, suport econòmic, acompanyament psicosocial,
etc. —, amb justificació de cada recomanació i informació de contacte directa."
        variant="caso"
      />
      <Card
        icon="/icon-nursing-home.png"
        title="Equip d'atenció a persones grans"
        description="Un equip d&#39;atenció a persones grans d&#39;una entitat necessita derivar un cas a un servei
especialitzat d&#39;una altra organització. A través de Red3Conecta, localitza el recurs,
comprova la disponibilitat i formalitza la derivació — tot des d&#39;un únic entorn, en
minuts."
        variant="caso"
      />
      <Card
        icon="/icons-call-on-iphone.png"
        title="Persona jove en situació de vulnerabilitat"
        description="Una persona jove en situació de vulnerabilitat accedeix des del mòbil al cercador i
navega de manera autònoma pels serveis disponibles al seu municipi, filtrats per tipus
de suport i requisits d&#39;accés."
        variant="caso"
      />
    </div>
  </div>
</div>

<style>
  .container {
    background-color: var(--color-light-brown);
    display: flex;
    flex-direction: column;
    padding: 3rem;
    gap: 2.5rem;
  }

  /* HEADER */
  .container__header h2 {
    font-size: 1.8rem;
    color: var(--color-black);
    margin: 0 0 1rem 0;
  }

  .container__header p {
    color: #444;
    line-height: 1.6;
    margin: 0;
  }
  li{
    background: rgba(255, 255, 255, 0.15); 
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    backdrop-filter: blur(4px);
    font-weight:bolder;
  }

  /* BLOCS */
  .container__blocs {
    display: flex;
    flex-direction: row;
    gap: 2rem;
  }

  .bloc {
    position: relative;
    border-radius: 1rem;
    flex: 1;
    overflow: hidden;               /* recorta overlay e imagen */
    background-size: cover;
    background-position: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .bloc:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }
  .bloc--a {
    background-image: url("public/imagenes/social-team.jpg");
    border-left: 6px solid rgba(255, 127, 80, 0.646);
  }

  .bloc--b {
    background-image: url("public/imagenes/social-media.jpg");
    border-left: 6px solid rgba(255, 127, 80, 0.646);
  }
  .bloc__overlay {
  position: absolute;
  inset: 0;
  background: rgba(255, 255, 255, 0.08); 
  backdrop-filter: blur(2px);            
  z-index: 0;
}

  .bloc:hover .bloc__overlay {
    background: rgba(0, 0, 0, 0.38); 
  }
  .bloc__content {
   position: relative;
  z-index: 1;
  margin: 1.5rem;                       
  padding: 2rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  color: white;

  background: rgba(0, 0, 0, 0.35);      
  backdrop-filter: blur(12px);           
  -webkit-backdrop-filter: blur(12px);   
  border-radius: 1rem;
  border: 1px solid rgba(255, 255, 255, 0.15); 
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
  }
  .bloc__content h3 {
    margin: 0;
    color: white;
    font-size: 1.3rem;
  }

  .bloc__tagline {
    font-style: italic;
    color: rgba(255, 255, 255, 0.85);
    margin: 0;
  }

  .bloc ul {
    padding-left: 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin: 0;
  }

  .bloc li {
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.9);
  }

  .bloc__result {
    margin: 0;
    font-weight: bold;
    font-size: 0.9rem;
    color: white;
    background: rgba(255, 255, 255, 0.15); 
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    backdrop-filter: blur(4px);
  }

  /* CASOS */
  .container__casos {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .casos__titulo {
    margin: 0;
    color: var(--color-black);
    font-size: 1.3rem;
  }

  .casos__grid {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
</style>