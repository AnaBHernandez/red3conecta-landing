---
const { t } = Astro.props;
const s9 = t.section9;
const awardsWithExtras = s9.awards;
const kpis = t.impact.kpis;
---

<section class="section9" aria-labelledby="s9-heading">
  <div class="container">
    <div class="section-header">
      <h2 id="s9-heading" class="section-title">{s9.title}</h2>
      <p class="section-intro">{s9.intro}</p>
    </div>

    <div class="awards-block">
      <h3 class="subsection-title">{s9.awardsTitle}</h3>
      <div class="accordion">
        {
          awardsWithExtras.map((award: any) => (
            <details class="accordion-item">
              <summary class="accordion-header">
                <span class="accordion-label">
                  {award.logo && (
                    <img class="item-logo" src={award.logo} alt={award.alt} />
                  )}
                  <span class="item-name">{award.placeholder}</span>
                </span>
                <span class="accordion-icon" aria-hidden="true" />
              </summary>
              <div class="accordion-body">
                <p class="item-desc">{award.description}</p>
                {award.info && <p class="item-info">{award.info}</p>}
              </div>
            </details>
          ))
        }
      </div>
    </div>

    <div class="funders-block">
      <h3 class="subsection-title">{s9.fundersTitle}</h3>
      <div class="carousel-wrap">
        <div class="carousel-track">
          {
            s9.funders.map((funder: any) => (
              <div
                class:list={["logo-item", funder.dark ? "logo-item--dark" : ""]}
              >
                <img src={funder.logo} alt={funder.name} />
              </div>
            ))
          }
          {
            s9.funders.map((funder: any) => (
              <div
                class:list={["logo-item", funder.dark ? "logo-item--dark" : ""]}
              >
                <img src={funder.logo} alt={funder.name} />
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .section9 {
    --s-bg: var(--color-cream-light);
    --s-bg-row: var(--color-surface-raised
    --s-bg-note: var(--color-border-subtle);
    --s-text-primary: #3a1f0d;
    --s-text-secondary: #6b3a26;
    --s-text-muted: #9e6b50;
    --s-accent: var(--color-border);
    --s-accent-light: var(--color-surface-raised
    --s-border: var(--color-border-subtle);
    --s-border-note: var(--color-border);
    --s-radius: 12px;

    var(--color-border): var(--s-bg);
    padding: clamp(3rem, 8vw, 6rem) 0;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 clamp(1rem, 5vw, 2.5rem);
    display: flex;
    flex-direction: column;
    gap: clamp(2.5rem, 6vw, 4rem);
    var(--color-border): var(--color-surface-raised
    border-radius: 12px;
  }


  .section-title {
    font-size: clamp(1.75rem, 4.5vw, 2.75rem);
    font-weight: 700;
    color: var(--s-text-primary);
    line-height: 1.2;
    margin: 0;
  }

  .section-intro {
    font-size: clamp(1rem, 2.2vw, 1.125rem);
    color: var(--s-text-secondary);
    line-height: 1.75;
    margin: 0;
  }

  .subsection-title {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    font-weight: 600;
    color: var(--s-text-primary);
    margin: 0 0 1.25rem 0;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--s-border);
  }

  .accordion {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .accordion-item {
    border: 1px solid var(--s-border);
    border-radius: var(--s-radius);
    overflow: hidden;
    var(--color-border): var(--color-white);
  }

  .accordion-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem;
    cursor: pointer;
    list-style: none;
    var(--color-border): var(--color-border);
    transition: var(--color-border) 0.2s ease;
  }

  .accordion-header::-webkit-details-marker {
    display: none;
  }

  .accordion-header:hover {
    var(--color-border): rgba(255, 130, 119, 0.861);
  }

  .accordion-label {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    min-width: 0;
  }

  .item-logo {
    height: 32px;
    width: auto;
    max-width: 100px;
    object-fit: contain;
    flex-shrink: 0;
    var(--color-border): var(--color-white);
    border-radius: 4px;
    padding: 2px 6px;
  }

  .item-name {
    font-weight: 700;
    color: var(--s-text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .accordion-icon {
    flex-shrink: 0;
    width: 12px;
    height: 12px;
    border-right: 2px solid var(--s-text-primary);
    border-bottom: 2px solid var(--s-text-primary);
    transform: rotate(45deg);
    transition: transform 0.25s ease;
    margin-top: -2px;
  }

  .accordion-item[open] .accordion-icon {
    transform: rotate(-135deg);
    margin-top: 2px;
  }

  .accordion-body {
    padding: 1.25rem;
    border-top: 1px solid var(--s-border);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    animation: accordionFadeIn 0.25s ease;
  }

  @keyframes accordionFadeIn {
    from {
      opacity: 0;
      transform: translateY(-6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .item-desc {
    color: var(--s-text-secondary);
    margin: 0;
    font-style: italic;
  }

  .item-info {
    color: var(--s-text-secondary);
    margin: 0;
    line-height: 1.75;
    font-size: 0.9375rem;
  }

  .funders-block {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .carousel-wrap {
    overflow: hidden;
    position: relative;
  }

  .carousel-wrap::before,
  .carousel-wrap::after {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    width: 60px;
    z-index: 2;
    pointer-events: none;
  }

  .carousel-wrap::before {
    left: 0;
    background: linear-gradient(to right, var(--s-bg), transparent);
  }

  .carousel-wrap::after {
    right: 0;
    background: linear-gradient(to left, var(--s-bg), transparent);
  }

  .carousel-track {
    display: flex;
    align-items: center;
    width: max-content;
    animation: logoScroll 18s linear infinite;
  }

  .carousel-track:hover {
    animation-play-state: paused;
  }

  @keyframes logoScroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (max-width: 560px) {
    .accordion-header {
      padding: 0.875rem 1rem;
    }
    .item-logo {
      height: 26px;
    }
    .item-name {
      font-size: 0.875rem;
    }
  }
</style>

<style is:global>
  .logo-item {
    background: #ffffff;
    border: 1px solid var(--color-border-subtle);
    border-radius: 12px;
    width: 160px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 12px;
    flex-shrink: 0;
    padding: 12px 16px;
  }

  .logo-item img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .logo-item--dark {
    background: #1a1a1a;
    border-color: #333;
  }
</style>
