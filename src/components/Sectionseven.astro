---
const { t } = Astro.props;
const s7 = t.section7;
---

<section class="vc">
  <div class="vc__container">
    <div class="vc__header">
      <div class="vc__dot-row">
        <div class="vc__dot"></div>
        <div class="vc__dot"></div>
        <div class="vc__dot"></div>
      </div>
      <h2 class="vc__title">{s7.title}</h2>
      <p class="vc__intro">{s7.intro}</p>
    </div>

    <div class="vc__block">
      <h3 class="vc__subtitle">{s7.driversTitle}</h3>
      <div class="vc__grid">
        {
          s7.drivers.map((driver: any) => (
            <div class="vc__card">
              <h4 class="vc__card-name">{driver.name}</h4>
              <p class="vc__card-desc">{driver.description}</p>
            </div>
          ))
        }
      </div>
    </div>

    <div class="s7__block vc__block--tinted">
      <h3 class="s7__subtitle">{s7.supportTitle}</h3>
      <div class="s7__quote-wrap">
        <span class="s7__quote-icon"></span>
        <blockquote class="vc__quote">{s7.supportQuote}</blockquote>
      </div>
      <p class="s7__network">{s7.networkNote}</p>
    </div>
  </div>
</section>

<style>
  .vc {
    background-color: var(--color-cream-light);
    padding: 56px 0 64px;
  }

  .vc__container {
    background-color:var(--color-surface);
     border-radius: 15px;
    max-width: var(--max-w-xl);
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .vc__header {
    padding: 32px 0 28px;
    border-bottom: var(--border-base) solid var(--color-border-subtle);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .vc__dot-row {
    display: flex;
    gap: 7px;
  }

  .vc__dot {
    width: 8px;
    height: 8px;
    border-radius: var(--radius-full);
    background: var(--color-border);
    animation: pulse 2.4s ease-in-out infinite;
  }
  .vc__dot:nth-child(2) {
    animation-delay: 0.4s;
    background: var(--color-border-subtle);
  }
  .vc__dot:nth-child(3) {
    animation-delay: 0.8s;
    background: var(--color-surface-raised);
  }

  @keyframes pulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 1;
    }
    50% {
      transform: scale(1.5);
      opacity: 0.7;
    }
  }

  .vc__title {
    font-family: var(--font-primary);
    font-size: clamp(1.5rem, 6vw, 2rem);
    font-weight: 700;
    color: var(--color-black);
    line-height: var(--leading-tight);
    margin: 0;
  }

  .vc__intro {
    font-size: var(--text-base);
    color: var(--color-black);
    line-height: var(--leading-loose);
    max-width: 680px;
    margin: 0;
  }

  .vc__block {
    padding: 32px 0 28px;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    border-bottom: var(--border-base) solid var(--color-border-subtle);
  }

  .vc__block--tinted {
    margin: 0 -24px;
    padding: 32px 24px 28px;
    background: var(--color-surface-raised);
    border-bottom: none;
    border-radius: 15px;
  }

  .vc__subtitle {
    font-family: var(--font-primary);
    font-size: var(--text-md);
    font-weight: 600;
    color: var(--color-black);
    margin: 0;
  }

  .vc__grid {
    display: grid;
    grid-template-columns: 1fr;
    justify-content: center;
    gap: var(--space-6);
  }

  .vc__card {
    background: var(--color-white);
    border-radius: var(--radius-md);
    padding: var(--space-6) var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    border-left: var(--border-thick) solid var(--color-border);
    box-shadow: var(--shadow-sm);
    transition:
      box-shadow var(--transition-base),
      border-color var(--transition-base),
      transform var(--transition-base);
  }

  .vc__card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--color-border-subtle);
    transform: translateX(4px);
  }

  .vc__card-name {
    font-family: var(--font-primary);
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-black);
    margin: 0;
  }

  .vc__card-desc {
    font-size: var(--text-sm);
    color: var(--color-black);
    line-height: var(--leading-base);
    margin: 0;
  }

  .vc__quote-wrap {
    position: relative;
    padding-left: 36px;
  }

  .vc__quote-icon {
    position: absolute;
    top: -4px;
    left: 0;
    font-family: Georgia, serif;
    font-size: 2.25rem;
    line-height: 1;
    color: var(--color-border);
    animation: quotePulse 3s ease-in-out infinite;
  }

  @keyframes quotePulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.4;
    }
  }

  .vc__quote {
    font-size: var(--text-sm);
    font-style: italic;
    line-height: var(--leading-base);
    color: var(--color-black);
    margin: 0;
  }

  .vc__network {
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--color-black);
    line-height: var(--leading-base);
    margin: 0;
  }


  @media (max-width: 450px) {
    .vc__container {
      padding: 0 16px;
    }

    .vc__block--tinted {
      margin: 0 -16px;
      padding: 28px 16px 24px;
    }

    .vc__card {
      padding: var(--space-5) var(--space-4);
    }

    .vc__quote-wrap {
      padding-left: 28px;
    }

    .vc__quote-icon {
      font-size: 2rem;
      top: -2px;
    }
  }


  @media (min-width: 600px) {
    .vc {
      padding: 64px 0 80px;
    }

    .vc__container {
      padding: 0 32px;
    }

    .vc__header {
      padding: 40px 0 32px;
      gap: var(--space-4);
    }

    .vc__title {
      font-size: var(--text-3xl);
    }

    .vc__block {
      padding: 40px 0 32px;
      gap: var(--space-5);
    }

    .vc__block--tinted {
      margin: 0 -32px;
      padding: 40px 32px 32px;
    }

    .vc__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .vc__quote-icon {
      font-size: 2.5rem;
    }
  }


  @media (min-width: 1024px) {
    .vc {
      padding: 80px 0 96px;
    }

    .vc__container {
      padding: 0 var(--space-8);
    }

    .vc__header {
      padding: 48px 0 40px;
      gap: var(--space-4);
    }

    .vc__block {
      padding: 48px 0 40px;
      gap: var(--space-6);
    }

    .vc__block--tinted {
      margin: 0 calc(-1 * var(--space-8));
      padding: 48px var(--space-8) 40px;
    }

    .vc__grid {
      grid-template-columns: repeat(auto-fit, minmax(280px, 360px));
    }

    .vc__quote-icon {
      font-size: 3rem;
    }
  }
</style>