---
// src/components/Impact.astro
import i18n from "../i18n/ca.json";
const { impact } = i18n;
---

<section class="stats" aria-labelledby="stats-title">
  <div class="stats__header">
    <h2 id="stats-title">{impact.title}</h2>
    <p>{impact.subtitle}</p>
  </div>

  <div class="stats__grid">
    {
      impact.kpis.map((kpi: any) => (
        <div class="kpi" role="region" aria-label={kpi.descripcion}>
          <span class="kpi__numero">{kpi.numero}</span>
          <p class="kpi__descripcion">{kpi.descripcion}</p>
        </div>
      ))
    }
  </div>

  <p class="stats__nota">
    {impact.note}
  </p>
</section>

<style>
  .stats {
    background-color: var(--color-light-brown);
    padding: 3rem;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* HEADER */
  .stats__header h2 {
    font-size: 1.8rem;
    color: var(--color-primary);
    margin: 0 0 1rem 0;
  }

  .stats__header p {
    color: #000000;
    line-height: 1.6;
    margin: 0;
  }

  /* GRID DE KPIS */
  .stats__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .kpi {
    background-color: var(--color-light-cream);
    backdrop-filter: blur(10px);
    border-radius: 1rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-bottom: 4px solid orange;
  }

  .kpi__numero {
    font-size: 2.2rem;
    font-weight: bold;
    color: var(--color-primary);
    line-height: 1;
  }

  .kpi__descripcion {
    margin: 0;
    color: var(--color-black);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  /* NOTA AL PIE */
  .stats__nota {
    margin: 0;
    color: var(--color-black); /* Corregido punto y coma */
    font-size: 0.8rem;
    font-style: italic;
    line-height: 1.5;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
    padding-top: 1rem;
  }
</style>
